{
  "name": "star-hotel",
  "version": "0.1.0",
  "description": "Star Hotel — VB6/Access modernization (Electron + React + SQLite)",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "electron-rebuild -f -w better-sqlite3,argon2 && electron-vite dev",
    "build": "electron-rebuild -f -w better-sqlite3,argon2 && electron-vite build",
    "preview": "electron-rebuild -f -w better-sqlite3,argon2 && electron-vite preview",
    "test": "pnpm rebuild better-sqlite3 && pnpm rebuild argon2 && vitest run",
    "posttest": "electron-rebuild -f -w better-sqlite3,argon2",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "codegen:api": "tsx scripts/export-openapi.ts && openapi-typescript src/server/openapi/openapi-spec.json -o src/shared/api/generated/openapi-types.ts",
    "codegen:api:check": "pnpm codegen:api && git diff --exit-code -- src/server/openapi/openapi-spec.json src/shared/api/generated/openapi-types.ts",
    "cleanup": "pnpm format && pnpm lint:fix && pnpm typecheck",
    "postinstall": "electron-rebuild -f -w better-sqlite3,argon2",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,argon2"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/electron": "^7.10.0",
    "@sentry/react": "10.42.0",
    "@tanstack/react-table": "^8.21.3",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "lucide-react": "^0.487.0",
    "openapi-fetch": "^0.17.0",
    "posthog-js": "^1.364.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.5",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.0.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.3.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.17",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
