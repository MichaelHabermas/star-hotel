# Copy to `.env` locally (never commit `.env`). Used by Electron main + Vite renderer.

# Embedded API (optional; see README)
# STAR_HOTEL_PORT=45123

# --- Observability (Epic E7) — leave unset to disable SDKs

# Sentry (public DSN; same value can be used in main and renderer)
SENTRY_DSN=
# Optional: release name for Sentry (e.g. star-hotel@0.1.0)
SENTRY_RELEASE=

# Optional: Crashpad minidump upload URL from your Sentry project (native crashes)
# See docs/CRASH-REPORTING.md
# SENTRY_MINIDUMP_URL=

# Vite-exposed (renderer) — must be prefixed with VITE_
VITE_SENTRY_DSN=

# PostHog (project API key; public)
VITE_POSTHOG_KEY=
# Default: https://app.posthog.com — use your region if different
# VITE_POSTHOG_HOST=https://app.posthog.com

# Logging: silent | error | warn | info | debug (main + Express)
STAR_HOTEL_LOG_LEVEL=info
